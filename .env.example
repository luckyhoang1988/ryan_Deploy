# ============================================================
# PyDeploy - Environment configuration (copy to .env)
# ============================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=pydeploy.settings.dev

# --- Database (PostgreSQL) ---
POSTGRES_DB=pydeploy
POSTGRES_USER=pydeploy
POSTGRES_PASSWORD=pydeploy
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis (Celery broker + cache) ---
REDIS_URL=redis://redis:6379/0

# --- Credential Vault ---
# Khóa mã hóa Fernet cho credential deploy (BẮT BUỘC ở prod).
# Sinh bằng: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PYDEPLOY_VAULT_KEY=

# --- Deployment engine ---
# Thư mục tạm trên máy đích (trong ADMIN$ = C:\Windows)
PYDEPLOY_TARGET_DIR=PyDeploy\Runner
# Tên service tạm tạo trên máy đích
PYDEPLOY_SERVICE_PREFIX=PyDeployRunner
# Số máy đẩy song song tối đa
PYDEPLOY_MAX_CONCURRENCY=15
# Timeout mỗi job (giây)
PYDEPLOY_JOB_TIMEOUT=1800

# --- Active Directory (Phase 5, tùy chọn) ---
AD_SERVER=
AD_BASE_DN=
AD_BIND_USER=
AD_BIND_PASSWORD=
