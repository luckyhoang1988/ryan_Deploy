# ============================================================
# RyanDeploy - Environment configuration (copy to .env)
# ============================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=ryandeploy.settings.dev

# --- Database (PostgreSQL) ---
POSTGRES_DB=ryandeploy
POSTGRES_USER=ryandeploy
POSTGRES_PASSWORD=ryandeploy
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis (Celery broker + cache) ---
REDIS_URL=redis://redis:6379/0

# --- Credential Vault ---
# Khóa mã hóa Fernet cho credential deploy (BẮT BUỘC ở prod).
# Sinh bằng: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
RYANDEPLOY_VAULT_KEY=

# --- Deployment engine ---
# Thư mục tạm trên máy đích (trong ADMIN$ = C:\Windows)
RYANDEPLOY_TARGET_DIR=RyanDeploy\Runner
# Tên service tạm tạo trên máy đích
RYANDEPLOY_SERVICE_PREFIX=RyanDeployRunner
# Số máy đẩy song song tối đa
RYANDEPLOY_MAX_CONCURRENCY=15
# Timeout mỗi job (giây)
RYANDEPLOY_JOB_TIMEOUT=1800
# Số luồng song song khi quét online toàn bộ máy (ping + TCP 135/445), mặc định 64
RYANDEPLOY_MACHINE_ONLINE_SCAN_WORKERS=64

# --- Active Directory (Phase 5, tùy chọn) ---
# Có thể để trống và cấu hình trực tiếp trong Web UI (Máy trạm → Cấu hình AD).
# Cấu hình lưu trong DB (mật khẩu mã hóa) sẽ được ưu tiên hơn các biến dưới đây.
AD_SERVER=
AD_BASE_DN=
AD_BIND_USER=
AD_BIND_PASSWORD=
AD_USE_SSL=false
